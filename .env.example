# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Supabase (required) ──────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://<PROJECT_ID>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<SUPABASE_ANON_KEY>
VITE_SUPABASE_PROJECT_ID=<PROJECT_ID>

# ── Supabase Edge Function Secrets (set via: supabase secrets set) ──────────
# GOOGLE_VISION_SA_KEY_V2  — Google Cloud service-account JSON (for OCR)
# LOVABLE_API_KEY           — Lovable AI Gateway key (for LLM estimation)
# ALLOWED_ORIGIN            — Restrict CORS to your production URL
#                             e.g. https://your-app.lovable.app
#                             Leave unset to allow any origin (development)
# ODOO_URL                  — Optional: Odoo instance base URL
# ODOO_DATABASE             — Optional: Odoo database name
# ODOO_USERNAME             — Optional: Odoo login user
# ODOO_API_KEY              — Optional: Odoo API key
